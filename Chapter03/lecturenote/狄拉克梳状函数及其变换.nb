Cell[CellGroupData[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "\:5b9a\:4e49\:90e8\:5206\:548c\:51fd\:6570", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"diracApprox", "[", 
     RowBox[{"t_", ",", "T_", ",", "N_"}], "]"}], ":=", 
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "/", "T"}], ")"}], "*", 
     RowBox[{"Sum", "[", 
      RowBox[{
       RowBox[{"Cos", "[", 
        RowBox[{"k", "*", 
         RowBox[{"(", 
          RowBox[{"2", " ", 
           RowBox[{"Pi", "/", "T"}]}], ")"}], "*", "t"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"k", ",", 
         RowBox[{"-", "N"}], ",", "N"}], "}"}]}], "]"}]}]}], "\n", 
   "\[IndentingNewLine]", 
   RowBox[{"(*", 
    RowBox[{
    "\:7ed8\:5236\:968f\:7740\:9879\:6570", " ", "N", " ", 
     "\:589e\:52a0\:7684\:6548\:679c"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{"Plot", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"diracApprox", "[", 
         RowBox[{"t", ",", "1", ",", "n"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"n", ",", 
          RowBox[{"{", 
           RowBox[{"5", ",", "20", ",", "100"}], "}"}]}], "}"}]}], "]"}], "//",
       "Evaluate"}], ",", 
     RowBox[{"{", 
      RowBox[{"t", ",", 
       RowBox[{"-", "0.5"}], ",", "1.5"}], "}"}], ",", 
     RowBox[{"PlotRange", "->", "All"}], ",", 
     RowBox[{"PlotLegends", "->", 
      RowBox[{"{", 
       RowBox[{"\"\<N=5\>\"", ",", "\"\<N=20\>\"", ",", "\"\<N=100\>\""}], 
       "}"}]}], ",", 
     RowBox[{"PlotStyle", "->", "Thick"}]}], "]"}]}]}]], "Input",
