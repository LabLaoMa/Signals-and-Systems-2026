Notebook[{
Cell[BoxData[
 RowBox[{
  RowBox[{"(*", "\:5b9a\:4e49\:9891\:7387\:54cd\:5e94\:51fd\:6570", "*)"}], 
  RowBox[{
   RowBox[{
    RowBox[{"H", "[", 
     RowBox[{"w_", ",", "a_"}], "]"}], ":=", 
    RowBox[{"1", "/", 
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"a", "*", 
        RowBox[{"Exp", "[", 
         RowBox[{
          RowBox[{"-", "I"}], "*", "w"}], "]"}]}]}], ")"}]}]}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", "\:8bbe\:7f6e\:53c2\:6570\:5217\:8868", "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"aValues", "=", 
     RowBox[{"{", 
      RowBox[{"0.3", ",", "0.6", ",", 
       RowBox[{"-", "0.3"}], ",", 
       RowBox[{"-", "0.6"}]}], "}"}]}], ";"}], "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "\:7ed8\:5236\:5e45\:9891\:7279\:6027", " ", "Magnitude", " ", 
     "Response"}], "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"magPlot", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Abs", "[", 
           RowBox[{"H", "[", 
            RowBox[{"w", ",", "a"}], "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "aValues"}], "}"}]}], "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"w", ",", 
         RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\"\<a = \>\"", ",", "#"}], "}"}], "]"}], "&"}], "/@", 
          "aValues"}], ")"}]}], ",", 
       RowBox[{"PlotStyle", "->", "Thick"}], ",", 
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<Frequency (\[Omega])\>\"", 
          ",", "\"\<Magnitude |H(e^{j\[Omega]})|\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Magnitude Response\>\""}], ",", 
       RowBox[{"GridLines", "->", "Automatic"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", 
    RowBox[{
    "\:7ed8\:5236\:76f8\:9891\:7279\:6027", " ", "Phase", " ", "Response"}], 
    "*)"}], "\[IndentingNewLine]", 
   RowBox[{
    RowBox[{"phasePlot", "=", 
     RowBox[{"Plot", "[", 
      RowBox[{
       RowBox[{"Evaluate", "[", 
        RowBox[{"Table", "[", 
         RowBox[{
          RowBox[{"Arg", "[", 
           RowBox[{"H", "[", 
            RowBox[{"w", ",", "a"}], "]"}], "]"}], ",", 
          RowBox[{"{", 
           RowBox[{"a", ",", "aValues"}], "}"}]}], "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"w", ",", 
         RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
       RowBox[{"PlotLegends", "->", 
        RowBox[{"(", 
         RowBox[{
          RowBox[{
           RowBox[{"Row", "[", 
            RowBox[{"{", 
             RowBox[{"\"\<a = \>\"", ",", "#"}], "}"}], "]"}], "&"}], "/@", 
          "aValues"}], ")"}]}], ",", 
       RowBox[{"PlotStyle", "->", "Thick"}], ",", 
       RowBox[{"Frame", "->", "True"}], ",", 
       RowBox[{"FrameLabel", "->", 
        RowBox[{"{", 
         RowBox[{"\"\<Frequency (\[Omega])\>\"", 
          ",", "\"\<Phase Arg(H(e^{j\[Omega]}))\>\""}], "}"}]}], ",", 
       RowBox[{"PlotLabel", "->", "\"\<Phase Response\>\""}], ",", 
       RowBox[{"GridLines", "->", "Automatic"}]}], "]"}]}], ";"}], 
   "\[IndentingNewLine]", "\n", 
   RowBox[{"(*", "\:5e76\:5217\:663e\:793a", "*)"}], "\[IndentingNewLine]", 
   RowBox[{"GraphicsGrid", "[", 
    RowBox[{
     RowBox[{"{", 
      RowBox[{"{", 
       RowBox[{"magPlot", ",", "phasePlot"}], "}"}], "}"}], ",", 
     RowBox[{"ImageSize", "->", "800"}]}], "]"}]}]}]], "Input",
