      RowBox[{"Exp", "[", 
       RowBox[{
        RowBox[{"-", "I"}], "*", "w"}], "]"}]}]}], ")"}]}]}]], "Input",
 CellLabel->"In[31]:=",ExpressionUUID->"3af91552-57ea-4ddd-98dc-6e074744b7e5"],

