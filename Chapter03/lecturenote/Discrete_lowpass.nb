          RowBox[{"{", 
           RowBox[{"a", ",", "aValues"}], "}"}]}], "]"}], "]"}], ",", 
       RowBox[{"{", 
        RowBox[{"w", ",", 
         RowBox[{"-", "Pi"}], ",", "Pi"}], "}"}], ",", 
